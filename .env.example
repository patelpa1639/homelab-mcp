# ============================================
# Homelab MCP — Configuration
# ============================================
# Copy this to .env and fill in your values.

# --- Proxmox Connection (required) ---
PROXMOX_HOST=192.168.1.100
PROXMOX_PORT=8006
PROXMOX_TOKEN_ID=user@pam!token-name
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_ALLOW_SELF_SIGNED=true

# --- Telegram Bot (optional) ---
TELEGRAM_BOT_TOKEN=123456789:ABCDefGHIjklMNOpqrsTUVwxyz
# Comma-separated list of Telegram user IDs allowed to use the bot.
# Get your ID from @userinfobot on Telegram. Leave empty to allow everyone.
TELEGRAM_ALLOWED_USERS=123456789,987654321

# --- AI Natural Language (optional, for Telegram) ---
# Provider: "openai" or "anthropic"
AI_PROVIDER=openai
AI_API_KEY=sk-...
# Model override (defaults: gpt-4o-mini for OpenAI, claude-sonnet-4-20250514 for Anthropic)
AI_MODEL=
